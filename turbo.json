{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "NODE_ENV",
    "VITE_DEV_SERVER_URL",
    "ELECTRON_RENDERER_PORT",
    "LABEE_MODE",
    "LABEE_PORT",
    "LABEE_DATA_DIR",
    "DECK_ROOT",
    "DECK_MAX_BYTES",
    "SKILLS_ROOTS",
    "SESSION_PASSWORD",
    "COOKIE_SECURE",
    "SIGNUP_ENABLED",
    "ANTHROPIC_API_KEY",
    "CLAUDE_BIN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["@labee/contracts#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
