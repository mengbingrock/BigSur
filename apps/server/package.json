{
  "name": "@labee/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "labee-server": "./dist/bin.mjs"
  },
  "scripts": {
    "dev": "bun run src/bin.ts",
    "build": "tsdown src/bin.ts --format esm --clean --out-dir dist",
    "start": "node dist/bin.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@labee/contracts": "workspace:*",
    "@labee/shared": "workspace:*",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "effect": "catalog:",
    "bcryptjs": "^3.0.3",
    "gray-matter": "^4.0.3",
    "iron-session": "^8.0.4",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "fuse.js": "^7.0.0"
  },
  "devDependencies": {
    "@labee/web": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
