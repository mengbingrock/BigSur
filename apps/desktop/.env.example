# Copy to apps/desktop/.env for local dev (gitignored). For packaged installs,
# place the same line in <userData>/oauth.env instead.
#
# The desktop app uses a Google "Desktop app" OAuth client (loopback + PKCE).
# Create one at:
#   https://console.cloud.google.com/apis/credentials
#   → Create Credentials → OAuth client ID → Application type: Desktop app
# Loopback redirect URIs (http://127.0.0.1:<any port>) are allowed automatically,
# so nothing needs registering. Google issues a client secret even for desktop
# clients and the token endpoint requires it (it's not confidential — it ships
# in the app — but it must be sent). Leave blank to hide the Google button.
GOOGLE_DESKTOP_CLIENT_ID=
GOOGLE_DESKTOP_CLIENT_SECRET=

# Stripe billing (the purchase plan proposed for Labee-provided access). Test or
# live keys; leave STRIPE_SECRET_KEY blank to disable billing. Price IDs come
# from your Stripe products (Pro/Max subscriptions + one-time credit packs).
STRIPE_SECRET_KEY=
STRIPE_SUBSCRIPTION_PRICES=
STRIPE_SUBSCRIPTION_PRICES_MAX=
STRIPE_CREDIT_PRICES=
# STRIPE_WEBHOOK_SECRET=whsec_…   (needed to grant the plan after payment)
