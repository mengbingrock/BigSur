# Copy to .env for local development. See docs/deploy.md for production notes.

# Session cookie sealing. Use a 32+ char random string in production.
SESSION_PASSWORD=

# Server port (default 3000) and SQLite location (default ./data/labee.sqlite).
# LABEE_PORT=3000
# LABEE_DB_PATH=./data/labee.sqlite

# Set to "false" for invite-only mode (no public signup form).
# SIGNUP_ENABLED=true

# --- "Sign in with Google" (OAuth 2.0). Leave blank to hide the Google button. ---
# Create an OAuth 2.0 Web Client at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI in the Google console.
# In dev the browser sits on the Vite origin. This repo's web dev server defaults
# to port 5733 (override with PORT). Register whichever port you actually use.
GOOGLE_REDIRECT_URI=http://localhost:5733/api/auth/google/callback

# --- Stripe payments (subscriptions + one-time credit top-ups). ---
# Leave STRIPE_SECRET_KEY blank to disable billing (the Settings → Billing panel
# then shows a "not configured" notice). Get keys at https://dashboard.stripe.com.
STRIPE_SECRET_KEY=
# Webhook signing secret. Create a webhook endpoint pointing at
#   <your-app>/api/billing/webhook
# subscribed to: checkout.session.completed, customer.subscription.created,
# customer.subscription.updated, customer.subscription.deleted. Copy its secret.
# Locally: `stripe listen --forward-to localhost:5733/api/billing/webhook`.
STRIPE_WEBHOOK_SECRET=
# Price IDs drive the catalog; name/amount/interval are fetched live from Stripe.
# Comma-separated lists (recommended — works with any prices you've created):
#   STRIPE_SUBSCRIPTION_PRICES      recurring price IDs → "pro" plan
#   STRIPE_SUBSCRIPTION_PRICES_MAX  recurring price IDs → "max" plan (optional)
#   STRIPE_CREDIT_PRICES            one-time price IDs (fixed OR pay-what-you-want)
STRIPE_SUBSCRIPTION_PRICES=
STRIPE_SUBSCRIPTION_PRICES_MAX=
STRIPE_CREDIT_PRICES=
# Back-compat single-price vars (used only if the *_PRICES lists above are empty).
# Credits granted on a one-time purchase = the amount actually paid.
STRIPE_PRICE_PRO=
STRIPE_PRICE_MAX=
STRIPE_PRICE_CREDITS_10=
STRIPE_PRICE_CREDITS_25=
STRIPE_PRICE_CREDITS_50=
# Absolute public URL used to build Checkout return links (optional; otherwise
# derived from the request Origin / Host). e.g. https://labee.online
# LABEE_PUBLIC_URL=https://labee.online

# --- Protocol search (apps/mcp-protocols) ---
# The protocol-search tool searches lab-protocol journals via free scholarly
# APIs (Crossref/Europe PMC — no key needed) and reagent vendors via a
# web-search provider. The keyless default (DuckDuckGo) works but can be
# rate-limited; set ONE of the keys below for reliable, CAPTCHA-free vendor
# search. Providers are tried in priority order: Brave → Google → DuckDuckGo.
#
# Brave Search API — free tier at https://brave.com/search/api/
# BRAVE_API_KEY=
#
# Google Programmable Search (Custom Search JSON API) — free 100 queries/day.
# Create a key at https://developers.google.com/custom-search/v1/overview and a
# search engine (set to "search the entire web") at https://programmablesearchengine.google.com
# GOOGLE_API_KEY=
# GOOGLE_CSE_CX=
#
# Force a single provider (brave | google | duckduckgo). Optional.
# PROTOCOLS_SEARCH_PROVIDER=
# Contact email sent to Crossref's "polite pool" for better reliability. Optional.
# PROTOCOLS_CONTACT_EMAIL=you@example.com
