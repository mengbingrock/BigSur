{
  "name": "@labee/monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "scripts"
    ],
    "catalog": {
      "effect": "4.0.0-beta.43",
      "@effect/platform-bun": "4.0.0-beta.43",
      "@effect/platform-node": "4.0.0-beta.43",
      "@effect/language-service": "0.84.2",
      "@effect/vitest": "4.0.0-beta.43",
      "@types/bun": "^1.3.9",
      "@types/node": "^24.10.13",
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "@types/react": "^19",
      "@types/react-dom": "^19",
      "tsdown": "^0.20.3",
      "typescript": "^5.7.3",
      "vitest": "^4.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-runner.ts dev",
    "dev:server": "node scripts/dev-runner.ts dev:server",
    "dev:web": "node scripts/dev-runner.ts dev:web",
    "dev:desktop": "node scripts/dev-runner.ts dev:desktop",
    "start": "turbo run start --filter=@labee/server",
    "build": "turbo run build",
    "build:desktop": "turbo run build --filter=@labee/desktop --filter=@labee/server",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives",
    "test": "turbo run test",
    "build:contracts": "turbo run build --filter=@labee/contracts",
    "db:generate:sqlite": "drizzle-kit generate --config=./db/drizzle.config.sqlite.ts",
    "db:generate:postgres": "drizzle-kit generate --config=./db/drizzle.config.postgres.ts",
    "dist:desktop:dmg": "node scripts/build-desktop-artifact.ts --platform mac --target dmg",
    "user": "node scripts/users.mjs",
    "deploy": "bash scripts/deploy.sh"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "oxlint": "^1.55.0",
    "turbo": "^2.3.3",
    "vitest": "catalog:"
  },
  "overrides": {
    "vite": "^8.0.0",
    "@effect/platform-node-shared": "4.0.0-beta.43"
  },
  "engines": {
    "bun": "^1.3.9",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.9"
}
