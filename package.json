{
  "name": "agent-monterey",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "user": "node scripts/users.mjs",
    "deploy": "bash scripts/deploy.sh",
    "electron:prepare": "node electron/prepare-standalone.mjs",
    "electron:dev": "concurrently -k -n next,electron \"next dev -p 3000\" \"wait-on tcp:127.0.0.1:3000 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:start": "npm run build && npm run electron:prepare && electron .",
    "dist": "npm run build && npm run electron:prepare && electron-builder",
    "dist:mac": "npm run build && npm run electron:prepare && electron-builder --mac",
    "dist:win": "npm run build && npm run electron:prepare && electron-builder --win",
    "dist:dir": "npm run build && npm run electron:prepare && electron-builder --dir"
  },
  "build": {
    "appId": "com.labee.desktop",
    "productName": "Labee",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@types/diff": "^7.0.2",
    "@xyflow/react": "^12.10.2",
    "bcryptjs": "^3.0.3",
    "diff": "^9.0.0",
    "fuse.js": "7.0.0",
    "gray-matter": "4.0.3",
    "iron-session": "^8.0.4",
    "lucide-react": "0.454.0",
    "mammoth": "^1.12.0",
    "next": "14.2.15",
    "pdf-parse": "^2.4.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "9.0.1",
    "remark-gfm": "4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "20.14.10",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.13",
    "typescript": "5.5.3",
    "wait-on": "^8.0.1"
  }
}
